# ─── Backend ───────────────────────────────────────────────────────────────────
# Dev local: SQLite
DATABASE_URL=sqlite:///./pharma.db

# Produção (Supabase): copiar a "Connection String" do painel do Supabase
# Seção: Project Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Origens permitidas no CORS (separadas por vírgula)
# Dev local
CORS_ORIGINS=http://localhost:5173
# Produção: adicionar a URL do Vercel
# CORS_ORIGINS=http://localhost:5173,https://pharma-route.vercel.app

# ─── Distâncias ────────────────────────────────────────────────────────────────
USE_OSRM=true
OSRM_BASE_URL=http://router.project-osrm.org
OSRM_TIMEOUT=3

# ─── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Dev local: deixar em branco (Vite usa proxy /api → localhost:8000)
# VITE_API_URL=

# Produção: URL do backend no Render (sem barra no final)
# VITE_API_URL=https://pharma-route-api.onrender.com
